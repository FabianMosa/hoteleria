generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

model Room {
  id          String    @id @default(cuid())
  name        String
  description String?
  /// URL pública de foto (CDN o almacenamiento); opcional para compatibilidad con datos antiguos.
  imageUrl    String?
  capacity    Int
  createdAt   DateTime  @default(now())

  bookings Booking[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash String
  createdAt     DateTime  @default(now())

  bookings Booking[]
}

model Booking {
  id         String         @id @default(cuid())
  roomId     String
  room       Room           @relation(fields: [roomId], references: [id], onDelete: Restrict)

  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  guestName  String
  guestEmail String

  startDate DateTime
  endDate   DateTime
  status    BookingStatus  @default(CONFIRMED)

  createdAt  DateTime       @default(now())

  @@index([roomId])
  @@index([userId])
  // Índice compuesto para acelerar el chequeo de solapamiento por rango de fechas.
  @@index([roomId, startDate, endDate])
}

